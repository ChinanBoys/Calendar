<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.hello.mapper.VoiceLogMapper">

    <insert id="insert" parameterType="com.example.hello.entity.VoiceLog"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO voice_log (user_id, raw_text, intent, parsed_json, create_time)
        VALUES (#{userId}, #{rawText}, #{intent}, #{parsedJson}, #{createTime})
    </insert>

    <delete id="deleteByUserId">
        DELETE FROM voice_log WHERE user_id = #{userId}
    </delete>

</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.hello.mapper.ReminderMapper">

    <resultMap id="ReminderMap" type="com.example.hello.entity.Reminder">
        <id property="id" column="id"/>
        <result property="eventId" column="event_id"/>
        <result property="userId" column="user_id"/>
        <result property="offsetMinutes" column="offset_minutes"/>
        <result property="fireTime" column="fire_time"/>
        <result property="sent" column="sent"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.hello.entity.Reminder"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO reminder (event_id, user_id, offset_minutes, fire_time, sent, create_time)
        VALUES (#{eventId}, #{userId}, #{offsetMinutes}, #{fireTime}, #{sent}, #{createTime})
    </insert>

    <delete id="deleteByEventId">
        DELETE FROM reminder WHERE event_id = #{eventId}
    </delete>

    <select id="selectByEventId" resultMap="ReminderMap">
        SELECT id, event_id, user_id, offset_minutes, fire_time, sent, create_time
        FROM reminder
        WHERE event_id = #{eventId}
        ORDER BY fire_time ASC
    </select>

</mapper>
